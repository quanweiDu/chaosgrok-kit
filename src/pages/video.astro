---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allVideos = await getCollection('videos');
const sorted = allVideos.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const platformColors: Record<string, string> = {
  'YouTube': '#ff4444',
  'B站': '#00a1d6',
  '抖音': '#000000',
  'Vimeo': '#1ab7ea',
  '自制': '#6b6b6b',
  '其他': '#6b6b6b',
};

function getYoutubeThumbnail(url: string): string | null {
  const match = url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  return match ? `https://img.youtube.com/vi/${match[1]}/hqdefault.jpg` : null;
}
---

<Layout title="Video — MR.QuanweiDU" description="影像记录。">

  <div class="video-page fade-1">

    <div class="video-hero">
      <h1 class="video-title">Video.</h1>
      <p class="video-sub">影像记录。</p>
    </div>

    <div class="video-list">
      {sorted.map((video) => {
        const isSelf = video.data.platform === '自制';
        const dateStr = video.data.pubDate.toISOString().slice(0, 7).replace('-', '.');
        const slug = video.slug;
        return (
          <div class="video-item" data-slug={slug}>
            {isSelf && video.data.file ? (
              <div class="video-player-wrap">
                <video class="video-player" controls preload="metadata">
                  <source src={video.data.file} type="video/mp4" />
                </video>
              </div>
            ) : (
              <div class="video-embed-wrap">
                {video.data.platform === 'YouTube' && getYoutubeThumbnail(video.data.url) ? (
                  <iframe
                    src={`https://www.youtube.com/embed/${video.data.url.match(/(?:v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/)?.[1]}`}
                    title={video.data.title}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                    class="video-iframe"
                  ></iframe>
                ) : (
                  <a href={video.data.url} target="_blank" rel="noopener" class="video-thumb-wrap">
                    <div class="video-thumb-placeholder">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="32" height="32">
                        <circle cx="12" cy="12" r="10"/>
                        <polygon points="10,8 16,12 10,16" fill="currentColor" stroke="none"/>
                      </svg>
                    </div>
                    <span class="video-platform-badge" style={`background: ${platformColors[video.data.platform]}`}>
                      {video.data.platform}
                    </span>
                  </a>
                )}
              </div>
            )}

            <div class="video-meta">
              <div class="video-meta-top">
                <span class="video-platform" style={`color: ${platformColors[video.data.platform]}`}>
                  {video.data.platform}
                </span>
                <span class="video-date">{dateStr}</span>
              </div>
              {isSelf ? (
                <h2 class="video-name">{video.data.title}</h2>
              ) : (
                <div class="video-name-row">
                  <h2 class="video-name">{video.data.title}</h2>
                  <a href={video.data.url} target="_blank" rel="noopener" class="video-goto">前往观看 ↗</a>
                </div>
              )}
              {video.data.titleZh && <p class="video-name-zh">{video.data.titleZh}</p>}
              {video.data.description && <p class="video-desc">{video.data.description}</p>}
            </div>

            <!-- 每个视频独立工具栏 -->
            <div class="video-toolbar">
              <button class="vtb-btn like-btn" title="点赞">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" class="like-icon"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                <span class="like-count">0</span>
              </button>
              <button class="vtb-btn bookmark-btn" title="收藏">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" class="bookmark-icon"><path d="M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
                <span class="bookmark-count">0</span>
              </button>
              <div class="vtb-space"></div>
              <div class="vtb-share-wrap">
                <button class="vtb-btn share-trigger" title="分享">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                  <span>分享</span>
                </button>
                <div class="vtb-dropdown">
                  <button class="vtb-share-item copy-link">复制链接</button>
                  <a class="vtb-share-item share-x" href="#" target="_blank" rel="noopener">分享到 X</a>
                  <a class="vtb-share-item share-weibo" href="#" target="_blank" rel="noopener">分享到微博</a>
                  <a class="vtb-share-item share-telegram" href="#" target="_blank" rel="noopener">分享到 Telegram</a>
                </div>
              </div>
            </div>

          </div>
        );
      })}
    </div>

  </div>

</Layout>

<script>
  function initVideoToolbars() {
    document.querySelectorAll('.video-item').forEach(item => {
      const slug = 'video:' + (item.getAttribute('data-slug') || Math.random());
      const pageUrl = window.location.href.split('?')[0] + '#' + (item.getAttribute('data-slug') || '');
      const title = item.querySelector('.video-name')?.textContent || document.title;

      // 点赞
      const likeBtn = item.querySelector('.like-btn') as HTMLButtonElement;
      const likeIcon = item.querySelector('.like-icon') as SVGElement;
      const likeCount = item.querySelector('.like-count') as HTMLElement;
      let liked = localStorage.getItem('liked:' + slug) === '1';
      let likes = parseInt(localStorage.getItem('likes:' + slug) || '0');

      function updateLike() {
        likeCount.textContent = String(likes);
        likeIcon.setAttribute('fill', liked ? 'currentColor' : 'none');
        likeBtn.classList.toggle('active-like', liked);
      }
      updateLike();
      likeBtn?.addEventListener('click', () => {
        liked = !liked;
        likes = liked ? likes + 1 : Math.max(0, likes - 1);
        localStorage.setItem('liked:' + slug, liked ? '1' : '0');
        localStorage.setItem('likes:' + slug, String(likes));
        updateLike();
      });

      // 收藏
      const bookmarkBtn = item.querySelector('.bookmark-btn') as HTMLButtonElement;
      const bookmarkIcon = item.querySelector('.bookmark-icon') as SVGElement;
      const bookmarkCount = item.querySelector('.bookmark-count') as HTMLElement;
      let bookmarked = localStorage.getItem('bookmarked:' + slug) === '1';
      let bookmarks = parseInt(localStorage.getItem('bookmarks:' + slug) || '0');

      function updateBookmark() {
        bookmarkCount.textContent = String(bookmarks);
        bookmarkIcon.setAttribute('fill', bookmarked ? 'currentColor' : 'none');
        bookmarkBtn.classList.toggle('active-bookmark', bookmarked);
      }
      updateBookmark();
      bookmarkBtn?.addEventListener('click', () => {
        bookmarked = !bookmarked;
        bookmarks = bookmarked ? bookmarks + 1 : Math.max(0, bookmarks - 1);
        localStorage.setItem('bookmarked:' + slug, bookmarked ? '1' : '0');
        localStorage.setItem('bookmarks:' + slug, String(bookmarks));
        updateBookmark();
      });

      // 分享
      const trigger = item.querySelector('.share-trigger') as HTMLButtonElement;
      const dropdown = item.querySelector('.vtb-dropdown') as HTMLElement;

      function toggleVtb(e: Event) {
        e.preventDefault();
        e.stopPropagation();
        dropdown?.classList.toggle('open');
      }

      trigger?.addEventListener('mousedown', toggleVtb);
      trigger?.addEventListener('touchstart', toggleVtb, { passive: false });

      document.addEventListener('click', (e) => {
        if (!trigger?.contains(e.target as Node)) dropdown?.classList.remove('open');
      });

      const copyBtn = item.querySelector('.copy-link') as HTMLButtonElement;
      copyBtn?.addEventListener('click', () => {
        navigator.clipboard.writeText(pageUrl).then(() => {
          copyBtn.textContent = '已复制 ✓';
          setTimeout(() => copyBtn.textContent = '复制链接', 2000);
          dropdown?.classList.remove('open');
        });
      });

      const shareX = item.querySelector('.share-x') as HTMLAnchorElement;
      if (shareX) shareX.href = `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(title)}`;
      const shareWeibo = item.querySelector('.share-weibo') as HTMLAnchorElement;
      if (shareWeibo) shareWeibo.href = `https://service.weibo.com/share/share.php?url=${encodeURIComponent(pageUrl)}&title=${encodeURIComponent(title)}`;
      const shareTelegram = item.querySelector('.share-telegram') as HTMLAnchorElement;
      if (shareTelegram) shareTelegram.href = `https://t.me/share/url?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(title)}`;
    });
  }

  initVideoToolbars();
  document.addEventListener('astro:page-load', initVideoToolbars);

  // 同一时间只允许一个视频播放
  function initVideoExclusion() {
    document.querySelectorAll('video.video-player').forEach(video => {
      video.addEventListener('play', () => {
        document.querySelectorAll('video.video-player').forEach(other => {
          if (other !== video) (other as HTMLVideoElement).pause();
        });
      });
    });
  }

  initVideoExclusion();
  document.addEventListener('astro:page-load', initVideoExclusion);
</script>

<style>
  .video-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 140px 40px 100px;
  }

  .video-hero { margin-bottom: 80px; }

  .video-title {
    font-family: var(--serif-en);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .video-sub {
    font-family: var(--serif-zh);
    font-size: 15px;
    color: var(--ink-ghost);
    margin: 0;
  }

  .video-list {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .video-player-wrap {
    width: 100%;
    background: #0a0a0a;
    margin-bottom: 20px;
  }

  .video-player {
    width: 100%;
    display: block;
    max-height: 480px;
    object-fit: contain;
  }

  .video-external-link {
    display: block;
    text-decoration: none;
    margin-bottom: 20px;
    position: relative;
  }

  .video-embed-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-bottom: 20px;
    background: #0a0a0a;
  }

  .video-iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .video-thumb-wrap {
    display: flex;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #f0efed;
    border: 1px solid var(--rule);
    align-items: center;
    justify-content: center;
    text-decoration: none;
    position: relative;
    transition: background 0.2s;
  }

  .video-thumb-wrap:hover { background: #e8e7e4; }

  .video-platform-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-family: var(--serif-en);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: white;
    padding: 3px 8px;
    border-radius: 2px;
  }

  .video-meta-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 6px;
  }

  .video-platform {
    font-family: var(--serif-en);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .video-date {
    font-family: var(--serif-en);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--ink-ghost);
  }

  .video-name {
    font-family: var(--serif-en);
    font-size: 20px;
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .video-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video-name-row {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .video-goto {
    font-family: var(--serif-en);
    font-size: 12px;
    letter-spacing: 0.05em;
    color: var(--ink-ghost);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .video-goto:hover { color: var(--ink); }

  .video-name-link { text-decoration: none; }
  .video-name-link:hover .video-name { color: var(--ink-light); }

  .video-name-zh {
    font-family: var(--serif-zh);
    font-size: 13px;
    color: var(--ink-ghost);
    margin: 0 0 8px;
  }

  .video-desc {
    font-family: var(--serif-zh);
    font-size: 14px;
    color: var(--ink-light);
    margin: 8px 0 0;
    line-height: 1.8;
  }

  /* 工具栏 */
  .video-toolbar {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
  }

  .vtb-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--ink-ghost);
    font-family: var(--serif-en);
    font-size: 13px;
    padding: 0;
    transition: color 0.2s;
  }

  .vtb-btn:hover { color: var(--ink); }
  .vtb-btn:active { transform: scale(0.92); }
  .vtb-btn.active-like { color: #c0392b; }
  .vtb-btn.active-like .like-icon { fill: currentColor; }
  .vtb-btn.active-bookmark { color: var(--ink); }
  .vtb-btn.active-bookmark .bookmark-icon { fill: currentColor; }

  .vtb-space { flex: 1; }

  .vtb-share-wrap { position: relative; }

  .vtb-dropdown {
    position: absolute;
    bottom: calc(100% + 16px);
    right: 0;
    background: none;
    min-width: 140px;
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: opacity 0.12s, transform 0.12s;
  }

  .vtb-dropdown.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .vtb-share-item {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    width: 100%;
    min-height: 44px;
    padding: 6px 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: var(--serif-en);
    font-size: 13px;
    color: var(--ink-light);
    text-decoration: none;
    text-align: right;
    transition: color 0.15s;
    -webkit-tap-highlight-color: transparent;
    white-space: nowrap;
  }

  .vtb-share-item:hover { color: var(--ink); }
  .vtb-share-item:last-child { border-bottom: none; }

  @media (max-width: 768px) {
    .video-page { padding: 100px 20px 80px; }
    .video-hero { margin-bottom: 48px; }
    .video-list { gap: 60px; }
  }
</style>
