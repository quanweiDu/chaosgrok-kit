---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allVideos = await getCollection('videos');
const sorted = allVideos.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const platformColors: Record<string, string> = {
  'YouTube': '#ff4444',
  'B站': '#00a1d6',
  '抖音': '#000000',
  'Vimeo': '#1ab7ea',
  '自制': '#6b6b6b',
  '其他': '#6b6b6b',
};
---

<Layout title="Video — MR.QuanweiDU" description="影像记录。">

  <div class="video-page fade-1">

    <div class="video-hero">
      <h1 class="video-title">Video.</h1>
      <p class="video-sub">影像记录。</p>
    </div>

    <div class="video-list">
      {sorted.map((video) => {
        const isSelf = video.data.platform === '自制';
        const dateStr = video.data.pubDate.toISOString().slice(0, 7).replace('-', '.');
        return (
          <div class={`video-item ${isSelf ? 'is-self' : 'is-external'}`}>
            {isSelf && video.data.file ? (
              <div class="video-player-wrap">
                <video
                  class="video-player"
                  controls
                  preload="none"
                  poster=""
                >
                  <source src={video.data.file} type="video/mp4" />
                </video>
              </div>
            ) : (
              <a href={video.data.url} target="_blank" rel="noopener" class="video-external-link">
                <div class="video-thumb-wrap">
                  <div class="video-thumb-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="32" height="32">
                      <circle cx="12" cy="12" r="10"/>
                      <polygon points="10,8 16,12 10,16" fill="currentColor" stroke="none"/>
                    </svg>
                  </div>
                </div>
              </a>
            )}
            <div class="video-meta">
              <div class="video-meta-top">
                <span class="video-platform" style={`color: ${platformColors[video.data.platform]}`}>
                  {video.data.platform}
                </span>
                <span class="video-date">{dateStr}</span>
              </div>
              {isSelf ? (
                <h2 class="video-name">{video.data.title}</h2>
              ) : (
                <a href={video.data.url} target="_blank" rel="noopener" class="video-name-link">
                  <h2 class="video-name">{video.data.title}</h2>
                </a>
              )}
              {video.data.titleZh && (
                <p class="video-name-zh">{video.data.titleZh}</p>
              )}
              {video.data.description && (
                <p class="video-desc">{video.data.description}</p>
              )}
            </div>
          </div>
        );
      })}
    </div>

  </div>

</Layout>

<style>
  .video-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 140px 40px 100px;
  }

  .video-hero {
    margin-bottom: 80px;
  }

  .video-title {
    font-family: var(--serif-en);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .video-sub {
    font-family: var(--serif-zh);
    font-size: 15px;
    color: var(--ink-ghost);
    margin: 0;
  }

  .video-list {
    display: flex;
    flex-direction: column;
    gap: 72px;
  }

  .video-item {}

  /* 自制视频 — 全宽播放器 */
  .video-player-wrap {
    width: 100%;
    background: #0a0a0a;
    margin-bottom: 24px;
  }

  .video-player {
    width: 100%;
    display: block;
    max-height: 480px;
    object-fit: contain;
  }

  /* 外链视频 — 封面占位 */
  .video-external-link {
    display: block;
    text-decoration: none;
    margin-bottom: 24px;
  }

  .video-thumb-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #f0efed;
    border: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .video-external-link:hover .video-thumb-wrap {
    background: #e8e7e4;
  }

  .video-thumb-placeholder {
    color: var(--ink-ghost);
    transition: color 0.2s;
  }

  .video-external-link:hover .video-thumb-placeholder {
    color: var(--ink);
  }

  /* 元信息 */
  .video-meta-top {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
  }

  .video-platform {
    font-family: var(--serif-en);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .video-date {
    font-family: var(--serif-en);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--ink-ghost);
  }

  .video-name {
    font-family: var(--serif-en);
    font-size: 20px;
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }

  .video-name-link {
    text-decoration: none;
  }

  .video-name-link:hover .video-name {
    color: var(--ink-light);
  }

  .video-name-zh {
    font-family: var(--serif-zh);
    font-size: 13px;
    color: var(--ink-ghost);
    margin: 0 0 10px;
  }

  .video-desc {
    font-family: var(--serif-zh);
    font-size: 14px;
    color: var(--ink-light);
    margin: 10px 0 0;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .video-page { padding: 100px 20px 80px; }
    .video-hero { margin-bottom: 48px; }
    .video-list { gap: 56px; }
  }
</style>
