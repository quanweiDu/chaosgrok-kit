---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search · 搜索" description="搜索文章、书籍、链接">

  <div class="search-page fade-1">

    <div class="search-header">
      <h1>Search <em>·</em> 搜索</h1>
      <div class="search-input-wrap">
        <input
          type="text"
          id="search-input"
          placeholder="输入关键词…"
          autocomplete="off"
          autofocus
        />
        <span class="search-count" id="search-count"></span>
      </div>
    </div>

    <div class="search-results" id="search-results">
      <p class="search-hint" id="search-hint">开始输入以搜索</p>
    </div>

  </div>

</Layout>

<script>
  interface SearchItem {
    type: string;
    slug: string;
    title: string;
    titleZh: string;
    description: string;
    url: string;
  }

  const typeLabel: Record<string, string> = {
    blog: 'Writing',
    books: 'Books',
    links: 'Links',
  };

  let data: SearchItem[] = [];

  async function loadIndex() {
    const res = await fetch('/search.json');
    data = await res.json();
  }

  function highlight(text: string, query: string): string {
    if (!query || !text) return text;
    const re = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(re, '<mark>$1</mark>');
  }

  function search(query: string) {
    const input = document.getElementById('search-input') as HTMLInputElement;
    const results = document.getElementById('search-results')!;
    const hint = document.getElementById('search-hint');
    const count = document.getElementById('search-count');

    const q = query.trim().toLowerCase();

    if (!q) {
      results.innerHTML = '';
      const p = document.createElement('p');
      p.className = 'search-hint';
      p.textContent = '开始输入以搜索';
      results.appendChild(p);
      if (count) count.textContent = '';
      return;
    }

    const matched = data.filter(item =>
      item.title.toLowerCase().includes(q) ||
      item.titleZh.toLowerCase().includes(q) ||
      item.description.toLowerCase().includes(q)
    );

    if (count) count.textContent = matched.length ? `${matched.length} 条结果` : '';

    if (!matched.length) {
      results.innerHTML = '<p class="search-hint">没有找到相关内容</p>';
      return;
    }

    results.innerHTML = matched.map(item => `
      <a class="result-item" href="${item.url}" ${item.type === 'links' ? 'target="_blank" rel="noopener"' : ''}>
        <span class="result-type">${typeLabel[item.type] ?? item.type}</span>
        <span class="result-title">${highlight(item.title, q)}${item.titleZh ? ' <span class="result-title-zh">' + highlight(item.titleZh, q) + '</span>' : ''}</span>
        ${item.description ? `<span class="result-desc">${highlight(item.description, q)}</span>` : ''}
      </a>
    `).join('');
  }

  async function init() {
    await loadIndex();
    const input = document.getElementById('search-input') as HTMLInputElement;
    input?.addEventListener('input', e => search((e.target as HTMLInputElement).value));

    // 如果 URL 带有 ?q= 参数，自动搜索
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    if (q && input) {
      input.value = q;
      search(q);
    }
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

<style>
  .search-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 80px 40px 120px;
  }

  .search-header {
    margin-bottom: 56px;
  }

  .search-header h1 {
    font-family: var(--serif-en);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 32px;
  }

  .search-header h1 em {
    color: var(--ink-ghost);
    font-style: normal;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 12px;
  }

  #search-input {
    flex: 1;
    border: none;
    outline: none;
    background: none;
    font-family: var(--serif-en);
    font-size: 18px;
    color: var(--ink);
    letter-spacing: 0.02em;
  }

  #search-input::placeholder { color: var(--ink-ghost); }

  .search-count {
    font-family: var(--serif-en);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--ink-ghost);
    white-space: nowrap;
  }

  .search-hint {
    font-family: var(--serif-en);
    font-size: 14px;
    color: var(--ink-ghost);
    letter-spacing: 0.04em;
  }

  .result-item {
    display: grid;
    grid-template-columns: 64px 1fr;
    grid-template-rows: auto auto;
    gap: 4px 16px;
    padding: 20px 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .result-item:first-child { border-top: 1px solid var(--rule); }
  .result-item:hover { opacity: 0.7; }

  .result-type {
    font-family: var(--serif-en);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-ghost);
    padding-top: 3px;
    grid-row: 1 / 3;
    align-self: start;
  }

  .result-title {
    font-family: var(--serif-en);
    font-size: 16px;
    color: var(--ink);
    line-height: 1.4;
  }

  .result-title-zh {
    font-family: var(--serif-zh, serif);
    font-size: 13px;
    color: var(--ink-light);
    margin-left: 8px;
  }

  .result-desc {
    font-size: 13px;
    color: var(--ink-light);
    line-height: 1.6;
    grid-column: 2;
  }

  mark {
    background: none;
    color: var(--ink);
    font-weight: 500;
    border-bottom: 1px solid var(--ink);
  }

  @media (max-width: 768px) {
    .search-page { padding: 60px 24px 80px; }
    .result-item { grid-template-columns: 52px 1fr; }
  }
</style>
