---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allLinks = await getCollection('links');

const categories = ['设计', '开发', '阅读', '思考', '工具', '音乐', '影像', '商业', '写作'];

const grouped = categories.reduce((acc, cat) => {
  acc[cat] = allLinks.filter(l => l.data.category === cat);
  return acc;
}, {} as Record<string, typeof allLinks>);
---

<Layout title="Links — MR.QuanweiDU" description="值得一读的链接，按类别整理。">

  <div class="links-page fade-1">

    <div class="links-hero">
      <h1 class="links-title">Links.</h1>
      <p class="links-sub">值得一读的地方。</p>
    </div>

    <div class="links-grid">
      {categories.map(cat => grouped[cat]?.length > 0 && (
        <div class="link-group">
          <h2 class="group-title">{cat}</h2>
          <ul class="group-list">
            {grouped[cat].map(link => (
              <li class="link-item">
                <a href={link.data.url} target="_blank" rel="noopener" class="link-anchor">
                  <span class="link-name">{link.data.title}</span>
                  {link.data.description && (
                    <span class="link-desc">{link.data.description}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>

</Layout>

<style>
  .links-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 140px 40px 100px;
  }

  .links-hero {
    margin-bottom: 80px;
  }

  .links-title {
    font-family: var(--serif-en);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .links-sub {
    font-family: var(--serif-zh);
    font-size: 15px;
    color: var(--ink-ghost);
    margin: 0;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 56px 48px;
  }

  .group-title {
    font-family: var(--serif-en);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-ghost);
    margin: 0 0 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rule);
  }

  .group-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .link-anchor {
    display: block;
    padding: 8px 0;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .link-anchor:hover {
    border-bottom-color: var(--rule);
  }

  .link-name {
    display: block;
    font-family: var(--serif-en);
    font-size: 14px;
    color: var(--ink);
    transition: color 0.15s;
  }

  .link-desc {
    display: block;
    font-family: var(--serif-zh);
    font-size: 12px;
    color: var(--ink-ghost);
    margin-top: 2px;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .links-page { padding: 100px 20px 80px; }
    .links-hero { margin-bottom: 48px; }
    .links-grid { grid-template-columns: 1fr 1fr; gap: 40px 24px; }
  }

  @media (max-width: 480px) {
    .links-grid { grid-template-columns: 1fr; gap: 36px; }
  }
</style>
