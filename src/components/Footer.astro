---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <span class="footer-follow">Follow</span>
      <div class="footer-socials">
        {socials.map(s => (
          <a href={s.href} target={s.href.startsWith('http') ? '_blank' : '_self'}
             rel="noopener" title={s.name} class="social-icon">
            <Fragment set:html={s.icon} />
          </a>
        ))}
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© {year} MR.QuanweiDU</span>
      <span class="footer-tagline">Thinking out loud, in writing.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--rule); margin-top: 80px; }

  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .footer-top {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule);
  }

  .footer-follow {
    font-family: var(--serif-en);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-ghost);
    white-space: nowrap;
  }

  .footer-socials {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--ink-ghost);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .social-icon:hover { color: var(--ink); }
  .social-icon svg { width: 16px; height: 16px; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
  }

  .footer-copy {
    font-family: var(--serif-en);
    font-size: 12px;
    color: var(--ink-ghost);
    letter-spacing: 0.05em;
  }

  .footer-tagline {
    font-family: var(--serif-en);
    font-size: 12px;
    font-style: italic;
    color: var(--ink-ghost);
  }

  @media (max-width: 768px) {
    .footer-inner { padding: 0 20px; }
    .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
    .footer-tagline { display: none; }
  }
</style>
