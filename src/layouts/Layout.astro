---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = '记录思考的轨迹。关于代码、逻辑与存在本身。',
  ogImage = '/og/default.png',
} = Astro.props;

const siteName = 'MR.QuanweiDU';
const siteUrl  = Astro.site ?? 'https://chaosgrok.com';
const fullTitle = title === 'Home' ? siteName : `${title} — ${siteName}`;

// 从 content 读取曲目列表，传给客户端
const trackEntries = await getCollection('tracks');
const tracksData = trackEntries
  .sort((a, b) => a.data.num.localeCompare(b.data.num))
  .map(t => ({
    num: t.data.num,
    name: t.data.name,
    src: `/music/${t.data.file}`,
  }));
---
---
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#ffffff" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:type"        content="website" />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(ogImage, siteUrl).toString()} />
  <meta property="og:url"         content={new URL(Astro.url.pathname, siteUrl).toString()} />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(ogImage, siteUrl).toString()} />
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="QuanweiDU" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- EB Garamond: 英文衬线，体积小，优先加载 -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" media="print" onload="this.media='all'" />
  <!-- Noto Serif SC: 只加载 400 字重，减少体积 -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400&display=swap" media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Noto+Serif+SC:wght@400&display=swap" />
  </noscript>
  <ViewTransitions />
</head>
<body>

  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">{siteName}</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Writing</a></li>
        <li><a href="/books">Books</a></li>
        <li><a href="/music">Music</a></li>
        <li><a href="/video">Video</a></li>
        <li><a href="/links">Links</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/consult">咨询</a></li>
        <li>
          <a href="/search" class="nav-search" title="搜索">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <Footer />

  <!-- 全局悬浮播放器 -->
  <div class="global-player" id="global-player" transition:persist>
    <div class="player-inner">
      <div class="player-track">
        <span class="player-num" id="player-num">01</span>
        <span class="player-name" id="player-name">—</span>
      </div>
      <div class="player-controls">
        <button class="ctrl-btn" id="btn-prev" title="上一首">&#8592;</button>
        <button class="ctrl-btn ctrl-play" id="btn-play" title="播放/暂停">&#9654;</button>
        <button class="ctrl-btn" id="btn-next" title="下一首">&#8594;</button>
      </div>
      <div class="player-progress">
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
      </div>
      <button class="ctrl-btn player-close" id="btn-close" title="关闭">&#10005;</button>
    </div>
  </div>

  <!-- 将服务端曲目数据注入客户端 -->
  <script type="application/json" id="tracks-data" set:html={JSON.stringify(tracksData)}></script>

  <!-- PWA Service Worker -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js');
      });
    }
  </script>

</body>
</html>

<style is:global>
  body.player-open { padding-bottom: 64px; }

  .global-player {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 300;
    background: rgba(15, 15, 15, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid rgba(255,255,255,0.08);
    transform: translateY(100%);
    transition: transform 0.4s ease;
  }

  .global-player.visible { transform: translateY(0); }

  .player-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .player-track {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    min-width: 0;
  }

  .player-num {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 11px;
    font-style: italic;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .player-name {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.04em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .player-controls {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ctrl-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    font-size: 14px;
    padding: 4px 8px;
    transition: color 0.2s;
    line-height: 1;
  }

  .ctrl-btn:hover { color: rgba(255,255,255,0.95); }
  .ctrl-play { font-size: 16px; color: rgba(255,255,255,0.85); }

  .player-progress {
    flex: 1;
    max-width: 200px;
  }

  .progress-bar {
    height: 1px;
    background: rgba(255,255,255,0.1);
    cursor: pointer;
  }

  .progress-fill {
    height: 100%;
    background: rgba(255,255,255,0.4);
    width: 0%;
    transition: width 0.5s linear;
  }

  .player-close { font-size: 12px; opacity: 0.4; }

  @media (max-width: 768px) {
    .player-inner { padding: 0 20px; gap: 16px; }
    .player-progress { display: none; }
  }
</style>

<script>
  // 从服务端注入的数据中读取曲目列表
  const tracksEl = document.getElementById('tracks-data');
  const TRACKS = tracksEl ? JSON.parse(tracksEl.textContent || '[]') : [];

  const audio = new Audio();
  audio.preload = 'none';
  let currentIndex = 0;
  let isPlaying = false;

  function getEls() {
    return {
      player:   document.getElementById('global-player'),
      btnPlay:  document.getElementById('btn-play'),
      btnPrev:  document.getElementById('btn-prev'),
      btnNext:  document.getElementById('btn-next'),
      btnClose: document.getElementById('btn-close'),
      nameEl:   document.getElementById('player-name'),
      numEl:    document.getElementById('player-num'),
      fill:     document.getElementById('progress-fill'),
    };
  }

  function updateUI() {
    const { nameEl, numEl, btnPlay } = getEls();
    const t = TRACKS[currentIndex];
    if (!t) return;
    if (nameEl) nameEl.textContent = t.name;
    if (numEl)  numEl.textContent  = t.num;
    if (btnPlay) btnPlay.innerHTML = isPlaying ? '&#9646;&#9646;' : '&#9654;';
  }

  function loadAndPlay(index) {
    if (!TRACKS.length) return;
    audio.pause();
    currentIndex = index;
    const t = TRACKS[index];
    audio.src = t.src;
    audio.load();
    const { fill, player } = getEls();
    if (fill) fill.style.width = '0%';
    if (player) { player.classList.add('visible'); document.body.classList.add('player-open'); }
    updateUI();
    audio.play().then(() => {
      isPlaying = true;
      updateUI();
    }).catch(() => {});
  }

  function togglePlay() {
    if (!TRACKS.length) return;
    if (!audio.src) { loadAndPlay(0); return; }
    if (isPlaying) {
      audio.pause();
      isPlaying = false;
    } else {
      audio.play().then(() => { isPlaying = true; }).catch(() => {});
    }
    updateUI();
  }

  audio.addEventListener('timeupdate', () => {
    const { fill } = getEls();
    if (fill && audio.duration) {
      fill.style.width = (audio.currentTime / audio.duration * 100) + '%';
    }
  });

  audio.addEventListener('ended', () => {
    if (TRACKS.length) loadAndPlay((currentIndex + 1) % TRACKS.length);
  });

  function bindControls() {
    const { btnPlay, btnPrev, btnNext, btnClose } = getEls();
    btnPlay?.addEventListener('click', togglePlay);
    btnNext?.addEventListener('click', () => loadAndPlay((currentIndex + 1) % TRACKS.length));
    btnPrev?.addEventListener('click', () => loadAndPlay((currentIndex - 1 + TRACKS.length) % TRACKS.length));
    btnClose?.addEventListener('click', () => {
      audio.pause();
      isPlaying = false;
      const { player } = getEls();
      player?.classList.remove('visible');
      document.body.classList.remove('player-open');
      updateUI();
    });
  }

  document.addEventListener('click', (e) => {
    const row = (e.target as Element).closest('[data-track-index]') as HTMLElement | null;
    if (!row) return;
    const idx = parseInt(row.dataset.trackIndex ?? '0');
    loadAndPlay(idx);
  });

  document.addEventListener('astro:page-load', bindControls);
  bindControls();
</script>
